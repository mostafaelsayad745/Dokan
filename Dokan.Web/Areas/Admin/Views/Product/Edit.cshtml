@model ProductVM

@{
    ViewBag.PageTitle = "Product managment";
    ViewBag.CardTitle = "create product";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<div class="row">
    <div class="col-md-4">
        <form method="post" asp-action="Edit" enctype="multipart/form-data">
            <input type="hidden" asp-for="Product.Id" />
            <input type="hidden" asp-for="Product.Img" />
            <div class="mb-3 form-group">
                <label asp-for="Product.Name" class="form-label"></label>
                <input asp-for="Product.Name" class="form-control" />
                <span asp-validation-for="Product.Name" class="text-danger"></span>
            </div>
            <div class="mb-3 form-group">
                <label asp-for="Product.Description" class="form-label"></label>
                <input asp-for="Product.Description" class="form-control" />
                <span asp-validation-for="Product.Description" class="text-danger"></span>
            </div>
            <div class="mb-3 form-group">
                <label asp-for="Product.Img" class="form-label"></label>
                <input type="file" name="file" id="Img" class="form-control" />
                <span asp-validation-for="Product.Description" class="text-danger"></span>
            </div>
            <div class="mb-3 form-group">
                <label asp-for="Product.CategoryId" class="form-label"></label>
                <select asp-for="Product.CategoryId" class="form-control" asp-items="Model.CategoryList">
                    <option disabled selected>-- Select Category --</option>
                </select>
                <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <button type="submit" value="save" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
    <div class="col-md-4">
        <div class="container">
            <img id="imgPreview" src="~/@Model.Product.Img" class="img-thumbnail"  width="500px" height="500px" />
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}