@model Brand

@{
    ViewBag.PageTitle = "Brand Management";
    ViewBag.CardTitle = "Create Brand";
    Layout = "~/Views/Shared/_Dashboard.cshtml";
}

<div class="card">
    <div class="card-body">
        <form method="post" asp-action="Create" enctype="multipart/form-data">
            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3 form-group">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-group">
                        <label asp-for="Slug" class="form-label"></label>
                        <input asp-for="Slug" class="form-control" />
                        <span asp-validation-for="Slug" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-group">
                        <label for="logoFile" class="form-label">Upload Brand Logo</label>
                        <input type="file" id="file" name="file" class="form-control" accept="image/*" />
                        <small class="text-muted d-block mt-2">
                            ✓ Recommended size: 200x200px
                        </small>
                    </div>

                    <div class="mb-3">
                        <button type="submit" class="btn btn-primary btn-lg">Create Brand</button>
                        <a href="@Url.Action("Index")" class="btn btn-secondary btn-lg">Cancel</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}